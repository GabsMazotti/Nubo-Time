{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alcateia/contratos/relatorio-de-analise.schema.json",
  "title": "RelatorioDeAnalise",
  "description": "Contrato Analista -> Gerente (handoff 6.3). Veredito acionavel por item, com numero.",
  "type": "object",
  "additionalProperties": false,
  "required": ["janela", "visaoGeral", "itens", "recomendacoes"],
  "properties": {
    "janela": { "type": "string", "description": "Periodo analisado", "examples": ["D0-D3", "ultimas 72h"] },
    "visaoGeral": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gastoUsd", "ftd", "cpaBlendedUsd"],
      "properties": {
        "gastoUsd": { "type": "number", "minimum": 0 },
        "ftd": { "type": "integer", "minimum": 0 },
        "cpaBlendedUsd": { "type": ["number", "null"], "description": "Null enquanto FTD nao for medido (sem tracker)" },
        "segundoDepositoPct": { "type": ["number", "null"] },
        "paybackDias": { "type": ["integer", "null"] },
        "roasD0": { "type": ["number", "null"] }
      }
    },
    "itens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["nome", "nivel", "metricas", "veredito", "acao"],
        "properties": {
          "nome": { "type": "string", "description": "Nome no padrao NOMENCLATURA" },
          "nivel": { "type": "string", "enum": ["campanha", "conjunto", "anuncio"] },
          "metricas": {
            "type": "object",
            "description": "Metricas-chave do item (camadas topo/meio/fundo/qualidade do 00-SISTEMA)",
            "additionalProperties": true
          },
          "veredito": {
            "type": "string",
            "enum": ["ESCALAR", "MANTER", "REFRESH", "PAUSAR-MATAR", "ESPERAR"]
          },
          "acao": { "type": "string", "description": "Acao numerica concreta", "examples": ["+20% budget / 48h", "excluir anuncio", "duplicar Post-ID -> CBO cost cap $11"] },
          "significativo": {
            "type": "boolean",
            "description": "True se >=25 conversoes do evento; caso contrario o veredito tende a ESPERAR"
          }
        }
      }
    },
    "recomendacoes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "realocacaoBudget": { "type": "array", "items": { "type": "string" } },
        "novosTestes": { "type": "array", "items": { "type": "string" } },
        "alertasConta": { "type": "array", "items": { "type": "string" }, "description": "CPM/aprovacao/frequencia" }
      }
    }
  }
}
