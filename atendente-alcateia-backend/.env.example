# === Atendente Alcateia — variáveis de ambiente ===
# Copie para .env (NUNCA versione o .env). No Supabase, use: supabase secrets set CHAVE=valor

# Anthropic (o "cérebro" do agente)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# Z-API (WhatsApp)
ZAPI_BASE_URL=https://api.z-api.io
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
# Número do closer que recebe os avisos (somente dígitos, com DDI). Ex.: 5531999998888
GABRIEL_WHATSAPP_NUMBER=

# Calendly
CALENDLY_EVENT_URL=https://calendly.com/alcateiamedia00/alcateia-media
CALENDLY_WEBHOOK_SECRET=

# Opcional: segredo simples para validar o webhook do Respondi (?secret=...)
RESPONDI_WEBHOOK_SECRET=

# Fuso para cálculo de horários nas mensagens
TIMEZONE=America/Sao_Paulo

# Injetadas automaticamente pelo runtime do Supabase Edge (NÃO precisa setar manualmente):
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
